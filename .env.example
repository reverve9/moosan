VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 부분 오픈 기간 동안 준비중 페이지 가드 플래그.
# 로컬/musanfesta-dev = true (전체 기능 노출)
# 프로덕션(musanfesta.com) = 설정하지 말 것 (false 간주)
VITE_DEV_MODE=false

# ─────────────────────────────────────────────────────────
# Solapi 알림톡 (server-only — VITE_ prefix 절대 금지)
# 카카오 비즈채널 + 검수 통과 템플릿 ID는 솔라피 콘솔에서 발급.
# 검수중 환불 템플릿은 빈 값으로 두면 발송 자동 skip.
# ─────────────────────────────────────────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
KAKAO_SENDER=
KAKAO_PFID=
KAKAO_TEMPLATE_PICKUP=
KAKAO_TEMPLATE_REFUND=

# ─────────────────────────────────────────────────────────
# 쿠키페이먼츠 (Cookiepayments / 키움페이 기반)
# 토스페이먼츠 대체. CARD = 자동 환불, KAKAOPAY/NAVERPAY = 수동 환불(운영진).
# COOKIEPAY_SANDBOX=true 면 sandbox.cookiepayments.com, false 면 www.cookiepayments.com
# ─────────────────────────────────────────────────────────
VITE_COOKIEPAY_API_ID=
COOKIEPAY_API_KEY=
COOKIEPAY_PAY2_ID=
COOKIEPAY_PAY2_KEY=
COOKIEPAY_SANDBOX=true

# ─────────────────────────────────────────────────────────
# (deprecated) 토스페이먼츠 — 심사 미통과로 비활성, 코드/env 제거는 Phase 6
# VITE_TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
# ─────────────────────────────────────────────────────────
